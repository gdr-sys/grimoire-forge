# Firebase — crea un progetto su console.firebase.google.com (tier Spark, gratuito)
# Abilita SOLO: Authentication > Google Sign-In
# NON abilitare Firestore, Storage o altri servizi Firebase
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id

# Google OAuth Client ID — ottenuto da console.cloud.google.com
# Abilita lo scope: https://www.googleapis.com/auth/drive.file
VITE_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# Ko-fi (opzionale — personalizza il link)
VITE_KOFI_URL=https://ko-fi.com/noemimarcolini

# Portfolio link (opzionale)
VITE_PORTFOLIO_URL=https://gdr-sys-portfolio2026.vercel.app/
